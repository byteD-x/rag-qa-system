# Shared auth
JWT_SECRET=change-me-in-env
AUTH_TOKEN_TTL_MINUTES=720

# Local demo accounts
ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=ChangeMe123!
MEMBER_USER_ID=22222222-2222-2222-2222-222222222222
MEMBER_EMAIL=member@local
MEMBER_PASSWORD=ChangeMe123!

# Logging
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST_PORT=5432
NOVEL_DATABASE_DSN=postgresql://rag:rag@postgres:5432/novel_app
KB_DATABASE_DSN=postgresql://rag:rag@postgres:5432/kb_app
GATEWAY_DATABASE_DSN=postgresql://rag:rag@postgres:5432/gateway_app

# Gateway routing
GATEWAY_TIMEOUT_SECONDS=180
GATEWAY_HOST_PORT=8080
NOVEL_HOST_PORT=8100
KB_HOST_PORT=8300
NOVEL_SERVICE_URL=http://novel-service:8100
KB_SERVICE_URL=http://kb-service:8200
VITE_GATEWAY_ORIGIN=http://localhost:8080

# Object storage / MinIO
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_HOST_PORT=9000
OBJECT_STORAGE_CONSOLE_HOST_PORT=9001
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=rag-assets
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_BACKEND=projection
EMBEDDING_MODEL=local-projection-512
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_BATCH_SIZE=64

# Upload / chat defaults
UPLOAD_PART_EXPIRES_SECONDS=3600
CHAT_MAX_EVIDENCE=8
CHAT_HISTORY_MESSAGES=8

# Worker runtime
NOVEL_BLOB_ROOT=/data/novel
NOVEL_WORKER_POLL_SECONDS=2
NOVEL_CHAPTER_BATCH_SIZE=10
KB_BLOB_ROOT=/data/kb
KB_WORKER_POLL_SECONDS=2
KB_SECTION_BATCH_SIZE=50
KB_CHUNK_BATCH_SIZE=500

# AI chat via OpenAI-compatible endpoint
AI_CHAT_ENABLED=true
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=
AI_MODEL=qwen3.5-plus
AI_CHAT_TIMEOUT_SECONDS=120
AI_DEFAULT_TEMPERATURE=0.7
AI_DEFAULT_MAX_TOKENS=2048
AI_SYSTEM_PROMPT=You are a concise and reliable Chinese assistant. Answer in Chinese unless the user asks otherwise.
AI_EXTRA_BODY_JSON={}
AI_PRICE_CURRENCY=CNY
AI_PRICE_TIERS_JSON=[{"max_input_tokens":131072,"input_price_per_1k_tokens":0.0008,"output_price_per_1k_tokens":0.0048},{"max_input_tokens":262144,"input_price_per_1k_tokens":0.002,"output_price_per_1k_tokens":0.012},{"max_input_tokens":1048576,"input_price_per_1k_tokens":0.004,"output_price_per_1k_tokens":0.024}]
AI_INPUT_PRICE_PER_1K_TOKENS=0.0008
AI_OUTPUT_PRICE_PER_1K_TOKENS=0.0048
