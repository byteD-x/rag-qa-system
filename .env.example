# Go API
HTTP_ADDR=:8080
POSTGRES_DSN=postgres://rag:rag@postgres:5432/rag?sslmode=disable
RAG_SERVICE_URL=http://py-rag-service:8000
MAX_UPLOAD_BYTES=524288000
AUTH_TOKEN_TTL_MINUTES=120
REDIS_URL=redis://redis:6379/0
INGEST_QUEUE_KEY=ingest_jobs

# Dev credentials
ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=ChangeMe123!
MEMBER_USER_ID=22222222-2222-2222-2222-222222222222
MEMBER_EMAIL=member@local
MEMBER_PASSWORD=ChangeMe123!

# PostgreSQL
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=minio:9000
S3_PUBLIC_ENDPOINT=localhost:19000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-raw
S3_USE_SSL=false
S3_PRESIGN_EXPIRY_MINUTES=30

# LLM (OpenAI-compatible)
# LLM_PROVIDER options:
# openai | deepseek | moonshot | qwen | zhipu | siliconflow | groq | together | fireworks | volcengine | ollama | custom
LLM_PROVIDER=qwen
# Use custom base URL when provider=custom or when overriding preset endpoint.
# Example: https://api.openai.com/v1
LLM_BASE_URL=
LLM_API_KEY=
# Embedding model examples:
# openai: text-embedding-3-small / text-embedding-3-large
# deepseek: deepseek-embedding
# qwen: text-embedding-v3
# zhipu: embedding-3
# siliconflow: BAAI/bge-m3
# ollama: nomic-embed-text
LLM_EMBEDDING_MODEL=text-embedding-v3
# Chat model examples:
# openai: gpt-4o-mini / gpt-4.1-mini
# deepseek: deepseek-chat / deepseek-reasoner
# moonshot: moonshot-v1-8k
# qwen: qwen3.5-plus / qwen-plus / qwen-turbo / qwen-max
# zhipu: glm-4-plus / glm-4-flash
# groq: llama-3.3-70b-versatile
# together: meta-llama/Llama-3.3-70B-Instruct-Turbo
# ollama: qwen2.5:14b
LLM_CHAT_MODEL=qwen3.5-plus
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_MILLISECONDS=600

# RAG Service
RAG_RETRIEVAL_TOP_N=24
RAG_RERANK_TOP_K=8
RAG_SOURCE_SENTENCE_LIMIT=6
RAG_EVIDENCE_MIN_SCORE=0.05
RAG_COMMON_KNOWLEDGE_MAX_RATIO=0.15

# RAG Optimization (新增)
# 混合检索配置
HYBRID_SEARCH_DENSE_WEIGHT=0.7
HYBRID_SEARCH_SPARSE_WEIGHT=0.3

# 多查询检索配置
MULTI_QUERY_ENABLED=false
MULTI_QUERY_MAX_VARIANTS=3
MULTI_QUERY_TIMEOUT_MS=500

# 重排序配置
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=8

# 查询缓存配置
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_HOURS=24
QUERY_CACHE_MAX_SIZE=10000

# 上下文压缩配置
CONTEXT_COMPRESSOR_ENABLED=false
CONTEXT_COMPRESSOR_MODEL=llm
CONTEXT_MAX_TOKENS=3200

# 分块策略配置
DEFAULT_CHUNK_SIZE=1024
DEFAULT_CHUNK_OVERLAP=100

# 意图分类配置
INTENT_CLASSIFICATION_ENABLED=true

# 元数据增强配置
METADATA_ENHANCEMENT_ENABLED=true
MAX_KEYWORDS=5

# Vector Index / Worker / Go API cleanup
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_MAX_RETRIES=3
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks
EMBEDDING_DIM=256
