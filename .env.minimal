# ------------------------------------------------------------
# .env.minimal — 单机最小可运行配置
# ------------------------------------------------------------
# 目标:用最少的必填项跑起一套功能可用、基本安全的演示。
# 未列出的变量都有面向 compose 内网的合理默认,通常无需修改;
# 需要精调时再从 .env.example(全量 340 行)复制对应项。
#
# 用法:cp .env.minimal .env,然后至少改「安全」与「LLM 接入」两组。

# ============ 安全(上线前必须改,勿用占位值) ============
# 高强度随机串,可用 `openssl rand -hex 32` 生成
JWT_SECRET=change-me-please-use-random-string
ADMIN_PASSWORD=ChangeMe123!
MEMBER_PASSWORD=ChangeMe123!

# ============ LLM 接入(不填则无法问答) ============
LLM_ENABLED=true
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus

# ============ 数据库 ============
# 默认账号 rag/rag 仅供本地内网;若改 POSTGRES_PASSWORD,
# 必须同步改下方两个 DSN 中的密码,否则服务连不上库。
POSTGRES_DB=postgres
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
GATEWAY_DATABASE_DSN=postgresql://rag:rag@postgres:5432/gateway_app
KB_DATABASE_DSN=postgresql://rag:rag@postgres:5432/kb_app

# ============ 向量库 ============
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb-evidence
